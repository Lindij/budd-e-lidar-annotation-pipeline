+def _try_register(name, import_path):
+    try:
+        module_path, cls_name = import_path.rsplit('.', 1)
+        module = __import__(module_path, fromlist=[cls_name])
+        __all__[name] = getattr(module, cls_name)
+    except Exception:
+        # Optional dataset dependencies may be missing; skip registration.
+        pass
